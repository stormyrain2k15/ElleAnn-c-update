+ninetyseven = candidates_for(97, slack=0)
+for sz, name in ninetyseven:
+    print(f'  • {name}  (sizeof={sz})')
+if not ninetyseven:
+    print('  (none — try ±8 below)')
+    for sz, name in candidates_for(97, slack=8):
+        print(f'  • {name}  (sizeof={sz})')
