new file mode 100644
index 0000000..5ffcf7e
--- /dev/null
+++ b/ElleAnn/Debug/test_phase6a_protobase.cpp
@@ -0,0 +1,95 @@
+/*══════════════════════════════════════════════════════════════════════════════
+ * test_phase6a_protobase.cpp — regression test pinning Phase 6a invariants.
+ *
+ *   Compile (Linux portable harness):
+ *       g++ -std=c++17 -I . -I _winstub \
+ *           -I ../Services/Elle.Service.Fiesta \
+ *           Debug/test_phase6a_protobase.cpp \
+ *           -o /tmp/test_phase6a
+ *
+ *   What this pins:
+ *     1. Foundational typedefs are bit-exact.
+ *     2. FiestaProtoBase.h coexists with FiestaPacket.h (no name
+ *        collisions; the redundant defs were removed in Phase 6a).
+ *     3. MAKE_NETCMDID round-trips (dept,subid) ↔ u16.
+ *     4. The auto-generated FiestaProtoTable.inc is sorted (binary
+ *        search precondition) and has every login-chain opcode the
+ *        production code references.
+ *══════════════════════════════════════════════════════════════════════════════*/
+
+#include "FiestaProtoBase.h"
+#include "FiestaPacket.h"
+#include "FiestaProtoTable.h"
+
+#include <cassert>
+#include <cstdio>
+
+int main() {
+    /* (1) Foundational typedef sizes. */
+    static_assert(sizeof(Fiesta::Name3)            ==   4, "");
+    static_assert(sizeof(Fiesta::Name4)            ==  16, "");
+    static_assert(sizeof(Fiesta::Name5)            ==  20, "");
+    static_assert(sizeof(Fiesta::Name8)            ==   8, "");
+    static_assert(sizeof(Fiesta::Name256Byte)      == 256, "");
+    static_assert(sizeof(Fiesta::NETCOMMAND)       ==   2, "");
+    static_assert(sizeof(Fiesta::NETPACKETHEADER)  ==   7, "");
+    static_assert(sizeof(Fiesta::NETPACKETHEADER_NAMED) == 2, "");
+    static_assert(sizeof(Fiesta::NETPACKETZONEHEADER)   == 6, "");
+    static_assert(sizeof(Fiesta::SHINE_XY_TYPE)    ==   8, "");
+    static_assert(sizeof(Fiesta::SHINE_COORD_TYPE) ==   9, "");
+
+    /* (2) MAKE_NETCMDID round-trip. */
+    static_assert(Fiesta::MAKE_NETCMDID(Fiesta::Dept::NC_USER, 0x06) == 0x0306, "");
+    static_assert(Fiesta::MAKE_NETCMDID(Fiesta::Dept::NC_MISC, 0x07) == 0x0207, "");
+    static_assert(Fiesta::OPCODE_DEPT (0x0207) == 0x02, "");
+    static_assert(Fiesta::OPCODE_SUBID(0x0207) == 0x07, "");
+
+    /* (3) Auto-gen table is sorted (binary search precondition). */
+    static_assert(Fiesta::OpcodeMetaCount() > 100,
+                  "FiestaProtoTable should hold >100 opcodes; regen step missed?");
+
+    /* (4) Every login-chain opcode resolves through the dispatch table. */
+    constexpr uint16_t kLoginChain[] = {
+        Fiesta::Op::NC_MISC_SEED_ACK,
+        Fiesta::Op::NC_USER_CLIENT_VERSION_CHECK_REQ,
+        Fiesta::Op::NC_USER_LOGIN_REQ,
+        Fiesta::Op::NC_USER_LOGIN_ACK,
+        Fiesta::Op::NC_USER_WORLDSELECT_REQ,
+        Fiesta::Op::NC_USER_WORLDSELECT_ACK,
+        Fiesta::Op::NC_USER_WILLLOGIN_REQ,
+        Fiesta::Op::NC_USER_WILLLOGIN_ACK,
+        Fiesta::Op::NC_MAP_LOGIN_REQ,
+        Fiesta::Op::NC_MAP_LOGINCOMPLETE_CMD,
+    };
+    int resolved = 0;
+    for (uint16_t op : kLoginChain) {
+        const auto* m = Fiesta::OpcodeMetaFor(op);
+        if (!m) {
+            std::printf("MISS  0x%04X (login-chain opcode missing from PDB table)\n", op);
+        } else {
+            std::printf("OK    0x%04X  %s  struct=%s sizeof=%d\n",
+                        op, m->opcode_name, m->struct_name, m->pdb_sizeof);
+            resolved++;
+        }
+    }
+    int expected = sizeof(kLoginChain) / sizeof(kLoginChain[0]);
+    if (resolved != expected) {
+        std::printf("\nFAIL: %d/%d login-chain opcodes resolved\n", resolved, expected);
+        return 1;
+    }
+
+    /* (5) Sanity: BuildPacket prepends size byte and emits dept-MSB. */
+    Fiesta::PROTO_NC_USER_LOGIN_REQ req{};
+    auto bytes = Fiesta::ToBytes(req);
+    auto frame = Fiesta::BuildPacket(Fiesta::Op::NC_USER_LOGIN_REQ, bytes);
+    /* sizeFlag = 0xFF then u16 LE length (since 274 > 0xFE). */
+    assert(frame[0] == 0xFF);
+    /* opcode dept = 0x03 first, then 0x06 — the X-Legend struct order. */
+    assert(frame[3] == 0x03 && frame[4] == 0x06);
+
+    std::printf("\nPhase 6a invariants: ALL PASS  (%d/%d login chain, "
+                "table=%zu rows, hot=%zu)\n",
+                resolved, expected,
+                Fiesta::OpcodeMetaCount(), Fiesta::HotOpcodeMetaCount());
+    return 0;
+}
