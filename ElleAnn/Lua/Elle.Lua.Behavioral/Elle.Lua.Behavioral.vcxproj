    </ClCompile>
  </ItemGroup>

  <!-- Deploy behavioural scripts next to the exe so LuaHost can load them. -->
  <ItemGroup>
    <None Include="scripts\**\*.lua">
      <DeploymentContent>true</DeploymentContent>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\ElleCore.Shared.vcxproj">
      <Project>{a1000000-0000-0000-0000-000000000001}</Project>
    </ProjectReference>
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
