      <TreatWarningAsError>false</TreatWarningAsError>
      <WarningLevel>Level3</WarningLevel>
    </ClCompile>
    <ClCompile Include="$(LuaDir)src\lzio.c" Condition="Exists('$(LuaDir)src\lzio.c')">
