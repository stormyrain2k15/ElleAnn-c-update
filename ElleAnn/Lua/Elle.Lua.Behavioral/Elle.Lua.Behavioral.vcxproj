    </ClCompile>
    <ClCompile Include="$(LuaDir)src\ltable.c" Condition="Exists('$(LuaDir)src\ltable.c')">
      <CompileAs>CompileAsC</CompileAs>
      <TreatWarningAsError>false</TreatWarningAsError>
      <WarningLevel>Level3</WarningLevel>
    </ClCompile>
    <ClCompile Include="$(LuaDir)src\ltablib.c" Condition="Exists('$(LuaDir)src\ltablib.c')">
      <CompileAs>CompileAsC</CompileAs>
      <TreatWarningAsError>false</TreatWarningAsError>
      <WarningLevel>Level3</WarningLevel>
    </ClCompile>
    <ClCompile Include="$(LuaDir)src\ltm.c" Condition="Exists('$(LuaDir)src\ltm.c')">
