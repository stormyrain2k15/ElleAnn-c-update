<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Material3 application theme — Compose handles all visual styling.
         This theme only exists to satisfy the Activity window background and
         status bar colour prior to Compose rendering. -->
    <style name="Theme.ElleAnn" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/elle_night</item>
        <item name="android:statusBarColor">@color/elle_night</item>
        <item name="android:navigationBarColor">@color/elle_night</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
